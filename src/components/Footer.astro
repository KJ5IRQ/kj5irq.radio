---
import { site } from '../data/site';
import Thistle from './Thistle.astro';
const year = new Date().getFullYear();
---

<footer class="site-footer saltire-bg">
  <div class="wrap">
    <div class="wc-footer">
      <Thistle size={40} />
      <p class="wc-cry">One nation. One dream.</p>
      <p class="meta wc-clan">Clan MacDuff · <span lang="la">Deus juvat</span></p>
    </div>
    <p class="footer-email">
      <a href={`mailto:${site.email}`}>{site.email}</a>
    </p>
    <ul class="footer-links">
      <li><a href={site.github} rel="me noopener">GitHub</a></li>
      <li><a href={site.linkedin} rel="me noopener">LinkedIn</a></li>
      <li><a href={site.qrz} rel="me noopener">QRZ</a></li>
      <li><a href="/colophon/">Colophon</a></li>
    </ul>
    <p class="meta">73 de {site.callsign} · {site.location} · {year}</p>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 2px solid var(--accent);
    margin-top: var(--space-9);
    padding-block: var(--space-8);
    background-color: var(--surface);
  }

  .wc-footer {
    text-align: center;
    margin-bottom: var(--space-8);
    padding-bottom: var(--space-7);
    border-bottom: 1px solid var(--rule);
  }

  .wc-cry {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 4vw, 2.5rem);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    margin-top: var(--space-3);
  }

  .wc-clan {
    margin-top: var(--space-3);
  }

  .footer-email {
    font-size: var(--size-h3);
    margin-bottom: var(--space-5);
  }

  .footer-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-5);
    list-style: none;
    padding: 0;
    margin-bottom: var(--space-6);
  }

  .footer-links a {
    font-family: var(--font-mono);
    font-size: var(--size-meta);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .footer-links a:hover {
    color: var(--link);
  }
</style>
