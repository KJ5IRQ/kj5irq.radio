---
// The Scottish thistle, stylized, in gold. Decorative.
interface Props {
  size?: number;
}
const { size = 44 } = Astro.props;
---

<svg
  class="thistle"
  width={size}
  height={size * 1.4}
  viewBox="0 0 40 56"
  fill="none"
  stroke="var(--accent)"
  stroke-width="1.8"
  stroke-linecap="round"
  aria-hidden="true"
>
  <!-- crown spikes -->
  <path d="M20 14 L20 4 M14 15 L9 7 M26 15 L31 7 M17 14 L14.5 6 M23 14 L25.5 6" />
  <!-- flower head -->
  <path d="M12 22 a8 9 0 1 1 16 0 a8 9 0 1 1 -16 0 Z" fill="var(--accent)" fill-opacity="0.18" />
  <path d="M14 17 L26 27 M26 17 L14 27 M20 15.5 L20 28.5 M12.8 22 L27.2 22" stroke-width="1.2" />
  <!-- calyx -->
  <path d="M15 29 Q20 34 25 29 L23 33 Q20 36 17 33 Z" fill="var(--accent)" fill-opacity="0.3" />
  <!-- stem -->
  <path d="M20 34 L20 52" />
  <!-- leaves -->
  <path d="M20 42 Q12 40 8 33 Q15 35 20 39 M20 46 Q28 44 32 37 Q25 39 20 43" />
</svg>

<style>
  .thistle {
    display: inline-block;
  }
</style>
