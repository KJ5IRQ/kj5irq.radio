<button class="theme-toggle" id="theme-toggle" aria-pressed="false" aria-label="Toggle dark theme">
  <svg class="icon-sun" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
    <circle cx="12" cy="12" r="4"></circle>
    <path d="M12 2v3M12 19v3M2 12h3M19 12h3M4.6 4.6l2.1 2.1M17.3 17.3l2.1 2.1M4.6 19.4l2.1-2.1M17.3 6.7l2.1-2.1"></path>
  </svg>
  <svg class="icon-moon" viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
  </svg>
</button>

<style>
  .theme-toggle {
    background: none;
    border: 1px solid var(--rule);
    color: var(--muted);
    padding: var(--space-2);
    cursor: pointer;
    line-height: 0;
    align-self: center;
  }

  .theme-toggle:hover {
    color: var(--ink);
    border-color: var(--muted);
  }

  .icon-moon {
    display: none;
  }

  :global([data-theme='dark']) .icon-sun {
    display: none;
  }

  :global([data-theme='dark']) .icon-moon {
    display: block;
  }
</style>

<script>
  const button = document.getElementById('theme-toggle');

  function isDark(): boolean {
    return document.documentElement.dataset.theme !== 'light';
  }

  function sync() {
    button?.setAttribute('aria-pressed', String(isDark()));
  }

  button?.addEventListener('click', () => {
    const next = isDark() ? 'light' : 'dark';
    document.documentElement.dataset.theme = next;
    try {
      localStorage.setItem('theme', next);
    } catch {}
    sync();
  });

  sync();
</script>
